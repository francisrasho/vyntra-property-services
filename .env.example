# --- Lead pipeline -------------------------------------------------------
# Where website leads are sent. "log" = demo mode (prints to server logs,
# no database needed). "supabase" = insert into the Vyntra OS Supabase.
LEAD_SINK=log

# Vyntra OS Supabase project (server-only — NEVER expose the service role key
# to the browser, never commit real values). Copy from the Vyntra OS project.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Future Vyntra OS portal login URL (Client / Contractor portal buttons).
# Leave blank to keep the portal buttons in "coming soon" state.
NEXT_PUBLIC_PORTAL_URL=
